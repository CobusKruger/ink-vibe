        { "name": "MD", "slug": "md", "size": "1rem", "fluid": false },
        { "name": "LG", "slug": "lg", "size": "1.125rem", "fluid": false },
        { "name": "XL", "slug": "xl", "size": "1.25rem", "fluid": false },
        { "name": "2XL", "slug": "2xl", "size": "1.5rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
        { "name": "3XL", "slug": "3xl", "size": "2rem", "fluid": { "min": "1.5rem", "max": "2rem" } }
      ],
      "lineHeight": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        { "slug": "sm", "name": "Small", "shadow": "0 2px 12px -2px hsl(220 20% 12% / 0.06)" },
        { "slug": "md", "name": "Medium", "shadow": "0 4px 20px -4px hsl(220 20% 12% / 0.08)" },
        { "slug": "lg", "name": "Large", "shadow": "0 12px 40px -8px hsl(220 20% 12% / 0.12)" }
      ]
    },
    "custom": {
      "radius": {
        "sm": "4px",
        "md": "6px",
        "lg": "8px",
        "xl": "12px",
        "2xl": "16px",
        "full": "9999px"
      },
      "lineHeight": {
        "tight": "1.2",
        "normal": "1.5",
        "relaxed": "1.7"
      },
      "fontWeight": {
        "regular": "400",
        "medium": "500",
        "semibold": "600",
        "bold": "700"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|surface",
      "text": "var:preset|color|text"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "lineHeight": "var:custom|line-height|tight"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|3xl"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|2xl"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|xl"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var:preset|font-size|lg"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var:preset|font-size|md"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var:preset|font-size|sm"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|primary"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|accent"
          }
        }
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|body",
      "fontSize": "var:preset|font-size|md",
      "lineHeight": "var:custom|line-height|normal"
    },
    "blocks": {
      "core/group": {
        "spacing": {
          "padding": {
            "top": "var:preset|spacing|s-24",
            "bottom": "var:preset|spacing|s-24",
            "left": "var:preset|spacing|s-24",
            "right": "var:preset|spacing|s-24"
          }
        }
      },
      "core/button": {
        "typography": {
          "fontFamily": "var:preset|font-family|ui"
        }
      },
      "core/navigation-link": {
        "typography": {
          "fontFamily": "var:preset|font-family|ui",
          "fontSize": "var:preset|font-size|md"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "var:preset|font-family|display",
          "fontSize": "var:preset|font-size|xl"
        }
      }
    }
  },
