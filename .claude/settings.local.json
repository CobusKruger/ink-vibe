{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python3 *)",
      "Bash(grep *)",
      "Bash(composer *)",
      "Bash(vendor/bin/pest *)",
      "Bash(./vendor/bin/pest *)",
      "Bash(vendor/bin/phpcs *)",
      "Bash(./vendor/bin/phpcs *)",
      "Bash(vendor/bin/phpstan *)",
      "Bash(./vendor/bin/phpstan *)",
      "Bash(php -l *)",
      "Bash(php --version)",
      "Bash(curl -sS \"https://cdn.jsdelivr.net/npm/@fontsource-variable/*)",
      "Bash(curl -sS \"https://data.jsdelivr.com/v1/package/npm/@fontsource-variable/*)",
      "Bash(claude install *)",
      "Read(//Users/cobus/.claude/**)",
      "WebSearch",
      "WebFetch(domain:docs.bmad-method.org)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:http-intake.logs.us5.datadoghq.com)",
      "Skill(update-config)",
      "Skill(fewer-permission-prompts)"
    ],
    "defaultMode": "acceptEdits"
  },
  "worktree": {
    "bgIsolation": "none"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.githubusercontent.com",
        "codeload.github.com",
        "cdn.jsdelivr.net",
        "data.jsdelivr.com",
        "registry.npmjs.org"
      ]
    }
  }
}
